{
  "chat.tools.terminal.autoApprove": {
    "npm --workspace @telepat/otto-extension": true,
    "npm --workspace @telepat/otto-relay": true,
    "npm --workspace @telepat/relay": true,
    "npm install": true,
    "npm run -ws --if-present test": true,
    "/^node packages/cli/dist/index\\.js extension info$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^node packages/cli/dist/index\\.js setup --help$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^node packages/cli/dist/index\\.js settings --help$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "npm run --workspace extension": true,
    "npm --workspace extension": true
  }
}