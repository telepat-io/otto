{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "plugins": [
    "node-workspace",
    {
      "type": "linked-versions",
      "groupName": "otto npm packages",
      "components": [
        "cli",
        "relay",
        "protocol",
        "extension"
      ]
    }
  ],
  "packages": {
    "packages/cli": {
      "release-type": "node",
      "package-name": "@telepat/otto",
      "component": "cli",
      "include-component-in-tag": false,
      "include-v-in-tag": true
    },
    "packages/relay": {
      "release-type": "node",
      "package-name": "@telepat/otto-relay",
      "component": "relay",
      "include-component-in-tag": true,
      "include-v-in-tag": true
    },
    "packages/shared-protocol": {
      "release-type": "node",
      "package-name": "@telepat/otto-protocol",
      "component": "protocol",
      "include-component-in-tag": true,
      "include-v-in-tag": true
    },
    "extension": {
      "release-type": "node",
      "package-name": "@telepat/otto-extension",
      "component": "extension",
      "include-component-in-tag": true,
      "include-v-in-tag": true
    }
  }
}
