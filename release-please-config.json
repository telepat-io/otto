{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "packages": {
    "packages/cli": {
      "release-type": "node",
      "package-name": "@telepat/otto",
      "component": "cli",
      "include-component-in-tag": false,
      "include-v-in-tag": true,
      "extra-files": [
        "packages/cli/.version",
        "packages/relay/.version",
        "packages/shared-protocol/.version",
        "extension/.version",
        {"type": "json", "path": "packages/relay/package.json", "jsonpath": "$.version"},
        {"type": "json", "path": "packages/shared-protocol/package.json", "jsonpath": "$.version"},
        {"type": "json", "path": "extension/package.json", "jsonpath": "$.version"}
      ]
    }
  }
}
