{
  "name": "otto",
  "version": "0.1.0",
  "description": "Otto remote browser automation monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "extension"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "dev": "npm --workspace @telepat/otto run dev:run --",
    "dev:relay": "npm --workspace @telepat/otto-relay run dev",
    "dev:cli": "npm --workspace @telepat/otto-cli run dev",
    "dev:ext": "npm --workspace @telepat/otto-extension run dev",
    "e2e:manual": "npm --workspace @telepat/otto-relay run e2e:manual",
    "check": "npm run -ws check",
    "lint": "npm run -ws lint"
  },
  "keywords": [
    "automation",
    "browser",
    "chrome-extension",
    "relay"
  ],
  "author": "Telepat",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "globals": "^17.4.0"
  }
}
