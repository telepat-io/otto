{
  "name": "otto",
  "version": "0.14.1",
  "description": "Ottomate Everything - Efficient Automation For Your Browser",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "extension"
  ],
  "scripts": {
    "build": "npm run -ws build",
    "dev": "npm --workspace @telepat/otto run dev:run --",
    "dev:relay": "npm --workspace @telepat/otto-relay run dev",
    "dev:cli": "npm --workspace @telepat/otto-cli run dev",
    "dev:ext": "npm --workspace @telepat/otto-extension run dev",
    "docs:start": "npm --prefix website run start",
    "docs:start:en": "npm --prefix website run start -- --locale en",
    "docs:start:zh": "npm --prefix website run start -- --locale zh-CN",
    "docs:preview:all-locales": "npm run docs:build && npm run docs:serve",
    "docs:build": "npm --prefix website run build",
    "docs:serve": "npm --prefix website run serve",
    "docs:deploy": "npm --prefix website run deploy",
    "e2e:manual": "npm --workspace @telepat/otto-relay run e2e:manual",
    "check": "npm run -ws check",
    "lint": "npm run -ws lint"
  },
  "keywords": [
    "automation",
    "browser",
    "chrome-extension",
    "relay"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepat-io/otto.git"
  },
  "bugs": {
    "url": "https://github.com/telepat-io/otto/issues"
  },
  "homepage": "https://docs.telepat.io/otto/",
  "author": "Telepat",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "c8": "^10.1.3",
    "eslint": "^10.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "globals": "^17.4.0"
  }
}
