{
  "name": "@telepat/otto-relay",
  "version": "0.11.0",
  "description": "Ottomate Everything - Efficient Automation For Your Browser",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "otto-relay": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepat-io/otto.git",
    "directory": "packages/relay"
  },
  "bugs": {
    "url": "https://github.com/telepat-io/otto/issues"
  },
  "homepage": "https://docs.telepat.io/otto/",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test test/integration.test.mjs && tsx --test test/unit/**/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text-summary --report-dir coverage --check-coverage --lines 90 --branches 90 tsx --test test/unit/**/*.test.ts",
    "e2e:manual": "node scripts/manual-e2e.mjs",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.mjs\" \"scripts/**/*.mjs\" --max-warnings 0"
  },
  "dependencies": {
    "@telepat/otto-protocol": "0.11.0",
    "jose": "^5.9.6",
    "nanoid": "^5.1.6",
    "ws": "^8.18.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}