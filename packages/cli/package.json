{
  "name": "@telepat/otto",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "otto": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:run": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "tsx --test test/**/*.test.ts",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"test/**/*.ts\" --max-warnings 0"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@telepat/otto-protocol": "0.1.0",
    "@telepat/otto-relay": "0.1.0",
    "adm-zip": "^0.5.16",
    "commander": "^14.0.0",
    "ink": "^6.3.0",
    "keytar": "^7.9.0",
    "nanoid": "^5.1.6",
    "react": "^19.0.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/react": "^19.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}