{
  "name": "@telepat/otto-sdk",
  "version": "0.15.0",
  "description": "TypeScript SDK for integrating 3rd-party JavaScript apps as Otto controllers",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/telepat-io/otto.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/telepat-io/otto/issues"
  },
  "homepage": "https://docs.telepat.io/otto/",
  "license": "MIT",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --format esm --dts --clean --out-dir dist",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --max-warnings 0",
    "test": "tsx --test test/**/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text-summary --report-dir coverage tsx --test test/**/*.test.ts",
    "dev": "tsx watch src/index.ts"
  },
  "dependencies": {
    "@telepat/otto-protocol": "0.15.0",
    "nanoid": "^5.1.6"
  },
  "devDependencies": {
    "@types/node": "^22",
    "c8": "^10.1.3",
    "tsup": "^8.3.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
